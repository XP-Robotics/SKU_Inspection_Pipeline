{
  "name": "sku-inspection-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Frontend for the Multi-SKU Visual Inspection Pipeline: SOP authoring, annotation review, dashboards, and runtime results.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "verify:fixtures": "esbuild scripts/verify-fixtures.ts --bundle --platform=node --format=cjs --packages=external --outfile=.verify-fixtures.cjs && node .verify-fixtures.cjs && rm -f .verify-fixtures.cjs",
    "verify:render": "esbuild scripts/verify-render.tsx --bundle --platform=node --format=cjs --jsx=automatic --packages=external --outfile=.verify-render.cjs && node .verify-render.cjs && rm -f .verify-render.cjs",
    "verify": "npm run typecheck && npm run verify:fixtures && npm run verify:render",
    "mock:init": "msw init public --save"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "esbuild": "^0.21.5",
    "msw": "^2.4.9",
    "typescript": "^5.5.4",
    "vite": "^5.4.6"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
