# Intercept all /api calls in the browser with mocked responses (no backend
# needed). Set to "false" once the FastAPI backend is running.
VITE_USE_MOCKS=true

# Where the FastAPI backend lives (used by the Vite dev proxy for /api).
# Only relevant when VITE_USE_MOCKS=false.
VITE_API_TARGET=http://localhost:8000
